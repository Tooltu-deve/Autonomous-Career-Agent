# ===== LLM =====
# Provider: anthropic | openai
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=your_anthropic_key_here
OPENAI_API_KEY=your_openai_key_here
LLM_MODEL=claude-opus-4-8

# ===== Auth =====
JWT_SECRET=change_me_to_a_long_random_string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ===== Postgres =====
POSTGRES_USER=career
POSTGRES_PASSWORD=career_pass
POSTGRES_DB=career_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ===== Qdrant =====
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# ===== RabbitMQ =====
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# ===== Service URLs (nội bộ docker network) =====
AUTH_SERVICE_URL=http://auth-service:8000
PROFILE_SERVICE_URL=http://profile-service:8000
SCRAPER_SERVICE_URL=http://scraper-service:8000
CV_AGENT_SERVICE_URL=http://cv-agent-service:8000
ATS_AGENT_SERVICE_URL=http://ats-agent-service:8000
